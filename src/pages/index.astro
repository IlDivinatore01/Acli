---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<BaseLayout title="Home" currentPage="/">
  <Hero />

  <!-- Welcome Section -->
  <section class="section welcome-section">
    <div class="container">
      <h2 class="section-title">Benvenuti al Circolo</h2>
      <p class="section-subtitle">
        Da oltre 50 anni, un punto di riferimento per la comunità di Bellinzago Novarese.
      </p>
      <div class="welcome-grid">
        <div class="welcome-card card">
          <div class="welcome-icon">☕</div>
          <h3>Bar & Caffetteria</h3>
          <p>Inizia la giornata con un espresso perfetto o goditi un aperitivo in compagnia.</p>
          <a href={`${base}menu/`} class="card-link">Scopri il menu →</a>
        </div>
        <div class="welcome-card card">
          <div class="welcome-icon">🎯</div>
          <h3>Attività & Eventi</h3>
          <p>Tornei di carte, serate a tema, eventi culturali e tanto altro per tutti.</p>
          <a href={`${base}eventi/`} class="card-link">I nostri eventi →</a>
        </div>
        <div class="welcome-card card">
          <div class="welcome-icon">🤝</div>
          <h3>Comunità</h3>
          <p>Un luogo di incontro dove coltivare amicizie e il senso di appartenenza.</p>
          <a href={`${base}storia/`} class="card-link">La nostra storia →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Membership Section -->
  <section class="section membership-section">
    <div class="container">
      <div class="membership-card card">
        <div class="membership-content">
          <div class="membership-icon">🪪</div>
          <h2>Diventa Socio ACLI</h2>
          <p class="membership-desc">
            Il Circolo ACLI San Giuseppe è un'associazione: l'accesso ai locali, la consumazione al bar e la partecipazione agli eventi <strong>sono strettamente riservati ai soci tesserati</strong>.
          </p>
          <div class="membership-prices">
            <div class="price-badge">
              <span class="price-label">Tessera Ordinaria</span>
              <span class="price-value">10€ <small>/ anno</small></span>
            </div>
            <div class="price-badge">
              <span class="price-label">Tessera Familiare</span>
              <span class="price-value">7€ <small>/ anno</small></span>
              <span class="price-subtext">(per chi ha già un familiare tesserato)</span>
            </div>
          </div>
          <p class="membership-note">
            <em>💡 Il tesseramento ha validità per l'intero anno solare e può essere comodamente effettuato in loco alla tua prima visita!</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Vieni a trovarci!</h2>
        <p>Il circolo è aperto a tutti. Passa a fare un saluto, bere un caffè o semplicemente a goderti un momento di relax.</p>
        <div class="cta-buttons">
          <a href={`${base}contatti/`} class="btn btn-primary">Come raggiungerci</a>
          <a href={`${base}team/`} class="btn btn-outline" style="color: white; border-color: rgba(255,255,255,0.4);">Il nostro team</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .welcome-section {
    background: var(--color-bg-warm);
  }

  .welcome-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .welcome-card {
    text-align: center;
    padding: var(--space-10) var(--space-6);
  }

  .welcome-icon {
    font-size: 3rem;
    margin-bottom: var(--space-4);
  }

  .welcome-card h3 {
    margin-bottom: var(--space-3);
  }

  .welcome-card p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .card-link:hover {
    color: var(--color-primary-dark);
    letter-spacing: 0.02em;
  }

  .cta-section {
    background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 50%, #3D2415 100%);
    padding: var(--space-20) 0;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .cta-content p {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
    line-height: 1.8;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .membership-section {
    padding-top: 0;
  }

  .membership-card {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6) var(--space-4);
    text-align: center;
  }

  .membership-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .membership-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-2);
  }

  .membership-desc {
    font-size: var(--text-base);
    margin-bottom: var(--space-6);
    color: var(--color-text-muted);
  }

  .membership-prices {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .price-badge {
    background: var(--color-bg);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 180px;
  }

  .price-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .price-value {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .price-value small {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .price-subtext {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .membership-note {
    color: var(--color-accent);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .welcome-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    
    .membership-prices {
      flex-direction: column;
    }
  }
</style>
