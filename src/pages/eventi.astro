---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import eventsData from '../data/events.json';
---

<BaseLayout 
  title="Eventi" 
  description="Scopri tutti gli eventi del Circolo ACLI San Giuseppe: feste, degustazioni, tornei, serate a tema e tanto altro."
  currentPage="/eventi/"
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="page-badge">🎉 I Nostri Eventi</span>
      <h1>Calendario<br/><span class="text-highlight">Eventi</span></h1>
      <p class="page-description">
        Il circolo è sempre in movimento! Scopri tutti gli eventi 
        e le iniziative che organizziamo durante l'anno.
      </p>
    </div>
  </section>

  <!-- Events Grid -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">I Prossimi Appuntamenti</h2>
      <p class="section-subtitle">
        Feste, degustazioni, tornei e serate a tema per tutti i gusti. Non perderti neanche un evento!
      </p>

      <div class="events-note card" style="margin-bottom: var(--space-8); padding: var(--space-5); border-left: 4px solid var(--color-primary); background: var(--color-bg-warm);">
        <p style="margin: 0;">🪪 <strong>Riservato ai Soci:</strong> La partecipazione agli eventi è strettamente riservata ai tesserati ACLI. La tessera ha validità annuale (10€ ordinaria, 7€ familiare) ed è sottoscrivibile comodamente in loco.</p>
      </div>

      <div class="events-grid">
        {eventsData.events.map((event) => (
          <EventCard 
            name={event.name}
            date={event.date}
            icon={event.icon}
            description={event.description}
            tags={event.tags}
            registrationStart={event.registrationStart}
            registrationEnd={event.registrationEnd}
            prices={event.prices}
            deposit={event.deposit}
            flyers={event.flyers}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="events-cta">
    <div class="container">
      <div class="cta-box card">
        <div class="cta-icon">📱</div>
        <h2>Resta aggiornato!</h2>
        <p>
          Segui le nostre pagine social per non perderti nessun evento, 
          aggiornamenti dell'ultimo minuto e foto delle serate!
        </p>
        <div class="cta-buttons" style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
          <a href="https://www.facebook.com/ACLIBellinzago" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="background: #1877F2; border-color: #1877F2;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px;">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Seguici su Facebook
          </a>
          <a href="https://www.instagram.com/aclibellinzago/" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); border: none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px;">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Seguici su Instagram
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visualizzatore locandina">
    <button class="lb-close" id="lb-close" aria-label="Chiudi">&times;</button>
    <div class="lb-content">
      <button class="lb-nav lb-prev" id="lb-prev" aria-label="Precedente">‹</button>
      <div class="lb-image-wrap">
        <img class="lb-image" id="lb-image" src="" alt="" />
      </div>
      <button class="lb-nav lb-next" id="lb-next" aria-label="Successiva">›</button>
    </div>
    <div class="lb-info">
      <span class="lb-title" id="lb-title"></span>
      <span class="lb-counter" id="lb-counter"></span>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 50%, #3D2415 100%);
    padding: calc(var(--nav-height) + var(--space-16)) 0 var(--space-16);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: 
      radial-gradient(circle at 25% 25%, white 1px, transparent 1px),
      radial-gradient(circle at 75% 75%, white 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .page-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background: rgba(200, 135, 43, 0.15);
    border: 1px solid rgba(200, 135, 43, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-primary-light);
    margin-bottom: var(--space-6);
  }

  .page-header h1 {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .text-highlight {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .page-description {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .events-cta {
    padding: var(--space-8) 0;
  }

  .cta-box {
    max-width: 550px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-10) var(--space-8);
    background: var(--color-bg-warm);
    border: 2px solid var(--color-primary-light);
  }

  .cta-icon {
    font-size: 3rem;
    margin-bottom: var(--space-3);
  }

  .cta-box h2 {
    margin-bottom: var(--space-3);
  }

  .cta-box p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.8;
  }

  /* === LIGHTBOX === */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    animation: lbFadeIn 0.2s ease;
  }

  .lightbox.open {
    display: flex;
  }

  @keyframes lbFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .lb-close {
    position: absolute;
    top: 16px;
    right: 24px;
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.7);
    background: none;
    border: none;
    cursor: pointer;
    z-index: 10;
    padding: 8px;
    line-height: 1;
    transition: color 0.2s;
  }

  .lb-close:hover {
    color: white;
  }

  .lb-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    max-width: 90vw;
    max-height: 80vh;
    position: relative;
  }

  .lb-image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 80vw;
    max-height: 80vh;
  }

  .lb-image {
    max-width: 100%;
    max-height: 78vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.5);
    user-select: none;
  }

  .lb-nav {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    font-size: 2rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .lb-nav:hover {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.3);
  }

  .lb-nav.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .lb-info {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 16px;
    color: rgba(255,255,255,0.7);
  }

  .lb-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: white;
  }

  .lb-counter {
    font-size: 0.8rem;
    background: rgba(255,255,255,0.1);
    padding: 4px 12px;
    border-radius: 999px;
  }

  .lb-counter.hidden {
    display: none;
  }

  @media (max-width: 768px) {
    .events-grid {
      grid-template-columns: 1fr 1fr;
    }

    .lb-nav {
      width: 36px;
      height: 36px;
      font-size: 1.4rem;
    }
  }

  @media (max-width: 600px) {
    .events-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Lightbox controller
  const lightbox = document.getElementById('lightbox');
  const lbImage = document.getElementById('lb-image') as HTMLImageElement;
  const lbTitle = document.getElementById('lb-title')!;
  const lbCounter = document.getElementById('lb-counter')!;
  const lbPrev = document.getElementById('lb-prev')!;
  const lbNext = document.getElementById('lb-next')!;
  const lbClose = document.getElementById('lb-close')!;

  let currentFlyers: string[] = [];
  let currentIndex = 0;

  function showImage(index: number) {
    currentIndex = index;
    lbImage.src = currentFlyers[index];

    // Nav visibility
    lbPrev.classList.toggle('hidden', currentFlyers.length <= 1 || index === 0);
    lbNext.classList.toggle('hidden', currentFlyers.length <= 1 || index === currentFlyers.length - 1);

    // Counter
    if (currentFlyers.length > 1) {
      lbCounter.textContent = `${index + 1} / ${currentFlyers.length}`;
      lbCounter.classList.remove('hidden');
    } else {
      lbCounter.classList.add('hidden');
    }
  }

  function openLightbox(flyers: string[], eventName: string) {
    currentFlyers = flyers;
    lbTitle.textContent = eventName;
    showImage(0);
    lightbox?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('open');
    document.body.style.overflow = '';
    lbImage.src = '';
  }

  // Bind all flyer buttons
  document.querySelectorAll<HTMLButtonElement>('.event-flyer[data-flyers]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const flyers = JSON.parse(btn.dataset.flyers || '[]');
      const name = btn.dataset.eventName || '';
      openLightbox(flyers, name);
    });
  });

  // Close
  lbClose.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Nav
  lbPrev.addEventListener('click', () => showImage(currentIndex - 1));
  lbNext.addEventListener('click', () => showImage(currentIndex + 1));

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && currentIndex > 0) showImage(currentIndex - 1);
    if (e.key === 'ArrowRight' && currentIndex < currentFlyers.length - 1) showImage(currentIndex + 1);
  });
</script>
