---
import BaseLayout from '../layouts/BaseLayout.astro';
import MenuCategory from '../components/MenuCategory.astro';
import menuData from '../data/menu.json';
---

<BaseLayout 
  title="Menu" 
  description="Scopri il menu del Circolo ACLI San Giuseppe: caffetteria, birre, vini, cocktail, analcolici e stuzzicheria."
  currentPage="/menu/"
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="page-badge">🍽️ Il Nostro Menu</span>
      <h1>Menu Bevande<br/><span class="text-highlight">& Stuzzicheria</span></h1>
      <p class="page-description">
        Dai un'occhiata alla nostra selezione di bevande e stuzzichini. 
        Qualità e tradizione a prezzi del circolo.
      </p>
    </div>
  </section>

  <!-- Menu Grid -->
  <section class="section">
    <div class="container">
      <div class="menu-grid">
        {menuData.categories.map((category) => (
          <MenuCategory 
            name={category.name} 
            icon={category.icon} 
            items={category.items} 
          />
        ))}
      </div>
      <div class="menu-note">
        <p>🪪 <strong>Riservato ai Soci:</strong> Il servizio bar e le consumazioni sono strettamente riservati ai tesserati ACLI. La tessera annuale (10€ ordinaria, 7€ familiare) può essere sottoscritta direttamente in loco.</p>
        <p style="margin-top: 12px; font-size: 0.85em;">💡 <strong>Nota:</strong> I prezzi potrebbero subire variazioni. Chiedi al bancone per eventuali offerte del giorno!</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 50%, #3D2415 100%);
    padding: calc(var(--nav-height) + var(--space-16)) 0 var(--space-16);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: 
      radial-gradient(circle at 25% 25%, white 1px, transparent 1px),
      radial-gradient(circle at 75% 75%, white 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .page-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background: rgba(200, 135, 43, 0.15);
    border: 1px solid rgba(200, 135, 43, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-primary-light);
    margin-bottom: var(--space-6);
  }

  .page-header h1 {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .text-highlight {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .page-description {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .menu-note {
    margin-top: var(--space-10);
    padding: var(--space-5) var(--space-6);
    background: var(--color-bg-warm);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-primary);
    text-align: center;
  }

  .menu-note p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .menu-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
