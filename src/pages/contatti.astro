---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contatti"
  description="Contatta il Circolo ACLI San Giuseppe di Bellinzago Novarese. Indirizzo, telefono, email e come raggiungerci."
  currentPage="/contatti/"
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="page-badge">📬 Contatti</span>
      <h1>Vieni a<br /><span class="text-highlight">Trovarci</span></h1>
      <p class="page-description">
        Siamo nel cuore di Bellinzago Novarese. Passa a trovarci o contattaci
        per qualsiasi informazione.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info">
          <div class="info-card card">
            <div class="info-icon">📍</div>
            <div>
              <h3>Indirizzo</h3>
              <p>Piazza Beata Rosa Gattorno 7</p>
              <p>28043 Bellinzago Novarese (NO)</p>
            </div>
          </div>

          <div class="info-card card">
            <div class="info-icon">📞</div>
            <div>
              <h3>Telefono</h3>
              <p><a href="tel:+393294227070">+39 329 422 7070</a></p>
            </div>
          </div>

          <div class="info-card card">
            <div class="info-icon">📧</div>
            <div>
              <h3>Email</h3>
              <p>
                <a href="mailto:circoloaclibellinzago@gmail.com"
                  >circoloaclibellinzago@gmail.com</a
                >
              </p>
            </div>
          </div>

          <div class="info-card card">
            <div class="info-icon">📱</div>
            <div>
              <h3>Social</h3>
              <div class="social-buttons">
                <a
                  href="https://www.facebook.com/ACLIBellinzago"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-btn"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path
                      d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                    ></path>
                  </svg>
                  Facebook
                </a>
                <a
                  href="https://www.instagram.com/aclibellinzago/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-btn social-btn-instagram"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path
                      d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                    ></path>
                  </svg>
                  Instagram
                </a>
              </div>
            </div>
          </div>

          <div class="info-card card hours-card">
            <div class="info-icon">🕐</div>
            <div>
              <h3>Orari di Apertura</h3>
              <div class="hours-table">
                <div class="hours-row">
                  <span class="day">Lunedì</span>
                  <span class="time">Chiuso</span>
                </div>
                <div class="hours-row">
                  <span class="day">Martedì</span>
                  <span class="time">Chiuso</span>
                </div>
                <div class="hours-row">
                  <span class="day">Mercoledì</span>
                  <span class="time">20:30 - 00:30</span>
                </div>
                <div class="hours-row">
                  <span class="day">Giovedì</span>
                  <span class="time">20:30 - 00:30</span>
                </div>
                <div class="hours-row">
                  <span class="day">Venerdì</span>
                  <span class="time">20:30 - 02:00</span>
                </div>
                <div class="hours-row">
                  <span class="day">Sabato</span>
                  <span class="time">17:00 - 02:00</span>
                </div>
                <div class="hours-row" style="align-items: flex-end;">
                  <span
                    class="day"
                    style="align-self: flex-start; margin-top: 5px;"
                    >Domenica</span
                  >
                  <div
                    style="display: flex; flex-direction: column; text-align: right; gap: 4px;"
                  >
                    <span class="time">10:00 - 13:00</span>
                    <span class="time">17:00 - 00:00</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="map-container">
          <div class="map-card card">
            <h3>📍 Dove Siamo</h3>
            <div class="map-wrapper">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2792.9983058058947!2d8.640340776940675!3d45.57047267107591!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47865df16380e6a3%3A0xcaea0d81d2afbae!2sCircolo%20Acli%20S.Giuseppe!5e0!3m2!1sen!2sit!4v1772978782920!5m2!1sen!2sit"
                width="100%"
                height="450"
                style="border:0; border-radius: var(--radius-lg);"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mappa Circolo ACLI San Giuseppe - Bellinzago Novarese"
              >
              </iframe>
            </div>
          </div>

          <div class="directions-note card">
            <h4>🚗 Come Raggiungerci</h4>
            <p>
              Il circolo si trova nel centro di Bellinzago Novarese, facilmente
              raggiungibile dalla SS32 del Lago Maggiore. Parcheggio disponibile
              nelle vicinanze.
            </p>
            <p>
              <strong>In treno:</strong> Stazione di Bellinzago Novarese (linea Novara-Milano),
              a 5 minuti a piedi dal circolo.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #2c1810 0%, #4a2c1a 50%, #3d2415 100%);
    padding: calc(var(--nav-height) + var(--space-16)) 0 var(--space-16);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: radial-gradient(
        circle at 25% 25%,
        white 1px,
        transparent 1px
      ),
      radial-gradient(circle at 75% 75%, white 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .page-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background: rgba(200, 135, 43, 0.15);
    border: 1px solid rgba(200, 135, 43, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-primary-light);
    margin-bottom: var(--space-6);
  }

  .page-header h1 {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .text-highlight {
    background: linear-gradient(
      135deg,
      var(--color-primary),
      var(--color-primary-light)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .page-description {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-8);
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-card h3 {
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
    font-family: var(--font-body);
    font-weight: 600;
  }

  .info-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .info-card a {
    font-size: var(--text-sm);
  }

  .social-buttons {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: #1877f2;
    color: white !important;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .social-btn:hover {
    background: #0e5fc0;
    transform: translateY(-1px);
    color: white;
  }

  .social-btn-instagram {
    background: linear-gradient(
      45deg,
      #f09433,
      #e6683c,
      #dc2743,
      #cc2366,
      #bc1888
    );
  }

  .social-btn-instagram:hover {
    background: linear-gradient(
      45deg,
      #e08323,
      #d5572c,
      #cb1633,
      #bb1256,
      #ab0778
    );
  }

  .hours-table {
    margin-top: var(--space-2);
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    padding: var(--space-1) 0;
    font-size: var(--text-sm);
    border-bottom: 1px solid var(--color-border);
    gap: var(--space-4);
  }

  .hours-row:last-child {
    border-bottom: none;
  }

  .day {
    color: var(--color-text-muted);
  }

  .time {
    font-weight: 600;
    color: var(--color-primary);
  }

  .map-card {
    padding: var(--space-6);
  }

  .map-card h3 {
    margin-bottom: var(--space-4);
  }

  .map-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .directions-note {
    margin-top: var(--space-4);
    padding: var(--space-6);
    background: var(--color-bg-warm);
    border-left: 4px solid var(--color-primary);
  }

  .directions-note h4 {
    margin-bottom: var(--space-3);
    font-family: var(--font-body);
  }

  .directions-note p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-2);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
