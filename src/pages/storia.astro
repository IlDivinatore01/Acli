---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';

const events = [
  {
    year: "1950",
    title: "La Fondazione",
    description: "Nasce il Circolo ACLI \"San Giuseppe\" a Bellinzago Novarese. I suoi pilastri storici fin dal principio sono il bar e l'annessa storica bocciofila, diventando un importante punto di ritrovo della comunità."
  },
  {
    year: "Anni '90 - 2000",
    title: "L'Evoluzione",
    description: "Con il calo d'interesse per le bocce, il circolo si reinventa e si apre sempre di più. Iniziano a essere proposte attività laboratoriali, ludiche ed eventi rivolti a bambini e famiglie."
  },
  {
    year: "Oggi",
    title: "Il Ricambio Generazionale",
    description: "Sotto nuove guide, nascono gli \"Aperitivisti\" (giovani under-25 che gestiscono i buffet) e si moltiplicano iniziative come Game Night, Aperitivi Musicali, Silent Disco e degustazioni."
  },
  {
    year: "2025",
    title: "I 75 Anni di Storia",
    description: "Il circolo festeggia orgogliosamente 75 anni di attività con mostre storiche e la caccia al tesoro \"Aclicatrace\". Oggi è una vera istituzione intergenerazionale capace di unire tradizione e modernità."
  }
];
---

<BaseLayout 
  title="La Nostra Storia" 
  description="Scopri la storia del Circolo ACLI San Giuseppe di Bellinzago Novarese, dal 1950 ad oggi, tra tradizioni, bocce e linguaggi contemporanei."
  currentPage="/storia/"
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="page-badge">📜 La Nostra Storia</span>
      <h1>Una Storia di<br/><span class="text-highlight">Comunità</span></h1>
      <p class="page-description">
        Dal 1950, una vera "fabbrica di ricordi" capace di unire 
        tradizione, amicizia e intergenerazionalità a Bellinzago.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="storia-intro">
        <div class="intro-content">
          <h2>Chi Siamo</h2>
          <p>
            Il <strong>Circolo ACLI "San Giuseppe" di Bellinzago Novarese</strong> è una vera e propria istituzione per la comunità locale. 
            Nato nel <strong>1950</strong> come tradizionale ritrovo legato alla storica bocciofila e frequentato originariamente da anziani, 
            ha saputo trasformarsi nel tempo diventando uno spazio di aggregazione dinamico, intergenerazionale e molto frequentato anche dai giovani.
          </p>
          <p>
            Oggi il nostro circolo unisce le sue profonde radici sociali e solidali (tipiche delle ACLI) a un'offerta contemporanea: 
            dalle storiche partite a carte alle <em>Game Night</em> con giochi da tavolo, dagli Aperitivi Musicali e <em>VenerdìVino</em> 
            agli eventi dedicati a famiglie e bambini. Una vera "fabbrica di ricordi" dove la tradizione incontra chi guarda al futuro.
          </p>
        </div>
        <div class="intro-stats">
          <div class="stat-item">
            <span class="stat-number">75</span>
            <span class="stat-label">Anni di storia</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">700+</span>
            <span class="stat-label">Tesserati</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Passione e Comunità</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <h2 class="section-title">Il Nostro Percorso</h2>
      <p class="section-subtitle">
        Ripercorri con noi le tappe fondamentali della nostra storia.
      </p>
      <Timeline events={events} />
    </div>
  </section>

  <!-- Values -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">I Nostri Valori</h2>
      <p class="section-subtitle">
        I principi che guidano le nostre attività da oltre mezzo secolo.
      </p>
      <div class="values-grid">
        <div class="value-card card">
          <div class="value-icon">🤝</div>
          <h3>Solidarietà</h3>
          <p>Ci impegniamo per il bene comune e per sostenere chi ha bisogno nella nostra comunità.</p>
        </div>
        <div class="value-card card">
          <div class="value-icon">👨‍👩‍👧‍👦</div>
          <h3>Famiglia</h3>
          <p>Il circolo è un luogo per tutti: un'estensione della famiglia, dove ognuno è benvenuto.</p>
        </div>
        <div class="value-card card">
          <div class="value-icon">🌱</div>
          <h3>Tradizione</h3>
          <p>Preserviamo le tradizioni del nostro territorio, valorizzando la cultura e l'identità locale.</p>
        </div>
        <div class="value-card card">
          <div class="value-icon">🎉</div>
          <h3>Convivialità</h3>
          <p>Crediamo nella gioia dello stare insieme, nel divertimento sano e nella buona compagnia.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #2C1810 0%, #4A2C1A 50%, #3D2415 100%);
    padding: calc(var(--nav-height) + var(--space-16)) 0 var(--space-16);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: 
      radial-gradient(circle at 25% 25%, white 1px, transparent 1px),
      radial-gradient(circle at 75% 75%, white 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .page-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background: rgba(200, 135, 43, 0.15);
    border: 1px solid rgba(200, 135, 43, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-primary-light);
    margin-bottom: var(--space-6);
  }

  .page-header h1 {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .text-highlight {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .page-description {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  .storia-intro {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .intro-content h2 {
    margin-bottom: var(--space-4);
  }

  .intro-content p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    line-height: 1.8;
  }

  .intro-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    text-align: center;
    padding: var(--space-5);
    background: var(--color-bg-warm);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .timeline-section {
    background: var(--color-bg-warm);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .value-card {
    text-align: center;
    padding: var(--space-8) var(--space-5);
  }

  .value-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }

  .value-card h3 {
    margin-bottom: var(--space-2);
    font-size: var(--text-lg);
  }

  .value-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .storia-intro {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .intro-stats {
      flex-direction: row;
      justify-content: center;
    }

    .values-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .intro-stats {
      flex-direction: column;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
