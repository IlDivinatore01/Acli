---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-wave">
    <svg viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0,40 C360,100 720,0 1080,60 C1260,90 1380,40 1440,50 L1440,100 L0,100 Z" fill="var(--color-bg-dark)"/>
    </svg>
  </div>
  <div class="footer-content">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="footer-brand">
            <span class="footer-brand-icon">🏠</span>
            <div>
              <h3>Circolo ACLI</h3>
              <p class="footer-brand-sub">San Giuseppe</p>
            </div>
          </div>
          <p class="footer-description">
            Un luogo dove vivere il tempo libero. Dal cuore di Bellinzago Novarese, il vostro circolo di riferimento.
          </p>
        </div>

        <div class="footer-col">
          <h4>Pagine</h4>
          <ul>
            <li><a href={`${base}`}>Home</a></li>
            <li><a href={`${base}menu/`}>Menu</a></li>
            <li><a href={`${base}eventi/`}>Eventi</a></li>
            <li><a href={`${base}storia/`}>La Nostra Storia</a></li>
            <li><a href={`${base}team/`}>Il Team</a></li>
            <li><a href={`${base}contatti/`}>Contatti</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Contatti</h4>
          <ul class="footer-contacts">
            <li>
              <span class="contact-icon">📍</span>
              <span>Piazza Beata Rosa Gattorno 7, Bellinzago Novarese (NO)</span>
            </li>
            <li>
              <span class="contact-icon">📞</span>
              <a href="tel:+393294227070">+39 329 422 7070</a>
            </li>
            <li>
              <span class="contact-icon">📧</span>
              <a href="mailto:circoloaclibellinzago@gmail.com">circoloaclibellinzago@gmail.com</a>
            </li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Seguici</h4>
          <a href="https://www.facebook.com/ACLIBellinzago" target="_blank" rel="noopener noreferrer" class="social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            <span>Facebook</span>
          </a>
          <a href="https://www.instagram.com/aclibellinzago/" target="_blank" rel="noopener noreferrer" class="social-link social-link-instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            <span>Instagram</span>
          </a>
          <div class="footer-hours">
            <h5>Orari</h5>
            <p>Lun - Mar: Chiuso</p>
            <p>Mer - Gio: 20:30 - 00:30</p>
            <p>Ven: 20:30 - 02:00</p>
            <p>Sab: 17:00 - 02:00</p>
            <p>Dom: 10:00 - 13:00 / 17:00 - 00:00</p>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {currentYear} Circolo ACLI "San Giuseppe" — Bellinzago Novarese. Tutti i diritti riservati.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    margin-top: var(--space-16);
  }

  .footer-wave {
    position: relative;
    margin-bottom: -2px;
  }

  .footer-wave svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  .footer-content {
    background: var(--color-bg-dark);
    color: var(--color-text-light);
    padding: var(--space-12) 0 var(--space-8);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-10);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .footer-brand-icon {
    font-size: 2rem;
  }

  .footer-brand h3 {
    color: var(--color-primary-light);
    font-size: var(--text-xl);
    margin: 0;
  }

  .footer-brand-sub {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-description {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .footer-col h4 {
    color: var(--color-primary-light);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col ul li {
    margin-bottom: var(--space-2);
  }

  .footer-col ul a {
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .footer-col ul a:hover {
    color: var(--color-primary-light);
  }

  .footer-contacts li {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
    font-size: var(--text-sm);
    color: rgba(245, 237, 230, 0.7);
  }

  .footer-contacts li span,
  .footer-contacts li a {
    word-break: break-word;
    overflow-wrap: break-word;
    min-width: 0;
  }

  .contact-icon {
    flex-shrink: 0;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(245, 237, 230, 0.7);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    color: white;
    background: #1877F2;
    border-color: #1877F2;
  }

  .social-link-instagram:hover {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    border-color: #dc2743;
  }

  .social-link + .social-link {
    margin-top: var(--space-2);
  }

  .footer-hours {
    margin-top: var(--space-6);
  }

  .footer-hours h5 {
    color: var(--color-primary-light);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-2);
  }

  .footer-hours p {
    font-size: var(--text-sm);
    color: rgba(245, 237, 230, 0.7);
    margin-bottom: var(--space-1);
  }

  .footer-bottom {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-dark);
    text-align: center;
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: rgba(245, 237, 230, 0.4);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
