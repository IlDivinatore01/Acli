---
interface Props {
  name: string;
  icon: string;
  items: { 
    name: string; 
    price: string | Record<string, string>;
  }[];
}

const { name, icon, items } = Astro.props;
---

<div class="menu-category card">
  <div class="category-header">
    <span class="category-icon">{icon}</span>
    <h3 class="category-name">{name}</h3>
  </div>
  <ul class="menu-items">
    {items.map((item) => (
      <li class="menu-item">
        <span class="item-name">{item.name}</span>
        <span class="item-dots"></span>
        {typeof item.price === 'string' ? (
          <span class="item-price">€ {item.price}</span>
        ) : (
          <div class="multi-prices">
            {Object.entries(item.price).map(([size, price]) => (
              <div class="multi-price-item">
                <span class="price-size">{size}</span>
                <span class="item-price">€ {price}</span>
              </div>
            ))}
          </div>
        )}
      </li>
    ))}
  </ul>
</div>

<style>
  .menu-category {
    padding: var(--space-8);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--color-border);
  }

  .category-icon {
    font-size: 1.8rem;
  }

  .category-name {
    font-size: var(--text-xl);
    color: var(--color-accent);
    margin: 0;
  }

  .menu-items {
    list-style: none;
  }

  .menu-item {
    display: flex;
    align-items: center; /* Modificato da baseline a center per gestire meglio i testi che vanno a capo */
    padding: var(--space-2) 0;
    gap: var(--space-2);
    width: 100%;
  }

  .menu-item:not(:last-child) {
    border-bottom: 1px solid rgba(232, 216, 200, 0.5);
  }

  .item-name {
    font-weight: 500;
    color: var(--color-text);
    /* Rimosso white-space: nowrap per evitare che forzino l'allargamento della pagina su mobile */
    line-height: 1.3;
    padding-right: 4px;
  }

  .item-dots {
    flex: 1;
    border-bottom: 1px dotted var(--color-border);
    min-width: 20px;
    margin-bottom: 4px;
  }

  .item-price {
    font-weight: 700;
    color: var(--color-primary);
    font-size: var(--text-lg);
    white-space: nowrap;
    font-family: var(--font-heading);
  }
  .multi-prices {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
  }

  .multi-price-item {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .price-size {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-weight: 600;
  }
</style>
